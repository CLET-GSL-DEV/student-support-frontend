# Only VITE_-prefixed vars reach the client bundle. Never put secrets here.
#
# Each backend service has its own FULL base URL: service path included,
# version segment excluded (the client appends /v1 itself). Two forms:
#  - /-relative path (the defaults when unset: /api/app and /api/iam) ->
#    same-origin calls. In dev the Vite server proxies /api/* to
#    VITE_DEV_API_PROXY_TARGET below, which sidesteps a gateway not sending
#    CORS headers for browser calls. Production serves the app same-origin
#    behind the gateway, so relative works there too.
#  - absolute URL (e.g. https://gateway.uat.rfdgh.com/api/hrm) -> bypasses
#    the proxy and hits that gateway directly. The gateway MUST send CORS
#    headers for browser calls; the URL's origin is added to the CSP
#    connect-src automatically (see vite.config.ts). The two services may
#    share one gateway or live on separate origins.
VITE_API_URL=/api/app
VITE_IAM_URL=/api/iam
# Dev-only reverse-proxy target for same-origin /api/* calls above (only used
# while VITE_API_URL / VITE_IAM_URL are relative). When unset, the shared vite
# config falls back to http://178.105.154.224:8000 — set it explicitly.
VITE_DEV_API_PROXY_TARGET=http://178.105.154.224:8090
VITE_APP_ENV=development
VITE_SENTRY_DSN=

# URL of the send-email Supabase Edge Function (supabase/functions/send-email),
# which holds the Resend API key server-side. The app POSTs here to send email
# (see src/api/email.ts). Leave unset to disable sending. Its origin is added to
# the CSP connect-src automatically (see vite.config.ts).
#  - deployed:    https://<project-ref>.supabase.co/functions/v1/send-email
#  - local serve: http://localhost:54321/functions/v1/send-email
VITE_EMAIL_FUNCTION_URL=

# Supabase backing store for the admin data layer, used when
# VITE_ADMIN_DATA_SOURCE=supabase (below). Public anon key only — never a
# service-role key. Its origin is added to the CSP connect-src (vite.config.ts).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Toggles the IAM /me session check: the on-login fetch AND the recurring
# session poller. Set false to make ZERO /me calls — the session user is then
# derived from the ZITADEL token claims instead. Defaults to true when unset.
VITE_SESSION_CHECK_ENABLED=true

# ZITADEL OIDC — Authorization Code + PKCE public client. NO client secret.
# This app owns its OWN /login + /auth/callback (no central login app) —
# register these redirect URIs on the ZITADEL application (port must match
# vite.config.ts's dev-server port):
#   redirect:      http://localhost:5290/auth/callback
#   post-logout:   http://localhost:5290/auth/logout/callback
#
# VITE_ZITADEL_AUTHORITY must be a BARE ORIGIN (scheme + host [+ port], no trailing
# path) and its SCHEME must match how ZITADEL is actually served:
#   - default self-hosted ZITADEL serves plain HTTP  -> http://localhost:8080
#   - ZITADEL Cloud / TLS-enabled instances           -> https://your-instance.zitadel.cloud
# Using https:// against an HTTP instance causes net::ERR_SSL_PROTOCOL_ERROR; a
# self-signed https cert must be trusted by the browser. This origin is also added
# to the app's CSP (see vite.config.ts / public/_headers).
VITE_ZITADEL_AUTHORITY=http://178.105.154.224:8090
# Optional. Only set this if ZITADEL is deployed with the interactive Login UI
# on a SEPARATE origin from the OIDC/API instance above (common for self-hosted
# multi-service ZITADEL deployments). monitorSession/automaticSilentRenew (see
# packages/auth/src/config.ts) open hidden iframes that hit the authority's
# /authorize endpoint, which may redirect here — if this origin isn't also
# allowed in the CSP, the browser blocks it (frame-src violation) and any
# cookie it sets gets rejected as cross-site. Added to connect-src/frame-src
# alongside VITE_ZITADEL_AUTHORITY (see vite.config.ts / public/_headers).
VITE_ZITADEL_LOGIN_UI_ORIGIN=
VITE_ZITADEL_CLIENT_ID=382061045507751954
VITE_ZITADEL_REDIRECT_URI=http://localhost:5290/auth/callback
VITE_ZITADEL_POST_LOGOUT_URI=http://localhost:5290/auth/logout/callback
# Scopes the token audience to this app's ZITADEL project. The role claim is
# requested regardless, so hasRole(...) works without it — but every app
# should set this so ProtectedRoute/hasRole checks see a consistent audience.
VITE_ZITADEL_PROJECT_ID=382060737410891794

# Admin Portal frontend-only data layer. 'mock' (default) serves dummy data
# from the in-memory repositories; 'api' routes through the gateway client
# stubs (blocked on the real backend contracts); 'supabase' reads/writes the
# Supabase backing store (needs VITE_SUPABASE_* above + the schema/seed pushed,
# see supabase/README.md).
VITE_ADMIN_DATA_SOURCE=mock
# Initial mock scenario: populated | empty | error. Switchable at runtime via
# the mock-scenario store; this only sets the starting value.
VITE_ADMIN_MOCK_SCENARIO=populated
