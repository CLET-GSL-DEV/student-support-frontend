# Local secrets for `supabase functions serve`. Copy to `.env.local` (gitignored)
# and fill in real values, then run:
#   supabase functions serve send-email --env-file supabase/functions/.env.local
#
# For DEPLOYED functions these are NOT read from this file — set them as project
# secrets instead:
#   supabase secrets set RESEND_API_KEY=re_xxx EMAIL_FROM="GSL Student Support <noreply@rfdgh.com>"

# Resend API key (https://resend.com/api-keys). Secret — never commit or expose to the browser.
RESEND_API_KEY=

# Default From address. Until a domain is verified at resend.com/domains, Resend
# only accepts the shared onboarding sender and only delivers to the account owner.
EMAIL_FROM=GSL Student Support <onboarding@resend.dev>

# CORS origin allowed to call this function. Use the exact app origin in
# production (e.g. https://app.rfdgh.com); "*" is convenient only for local dev.
EMAIL_ALLOWED_ORIGIN=*
